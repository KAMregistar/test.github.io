      "definition": "Povijest djela je kratak nestrukturirani tekst koji sadržava pojedinosti o nastanku, recepciji i interpretaciji djela.",
      "property": "http://www.registar.kam.hr/Elements/d/#P20016",
      "mappingCurie": "kamd:P20016",
      "mappingBasis": "label"
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "5.2",
      "label": "Plan sređivanja",
      "obligation": "Obvezno kad je primjenjivo, pod određenim uvjetima (vidi 5.2.2 Uvjeti navođenja plana sređivanja)",
      "required": true,
      "repeatable": true,
      "definition": "Plan sređivanja je strukturirani ili nestrukturirani tekst u kojemu se objašnjava sadašnji i/ili planirani sustav organizacije fonda ili zbirke.",
      "property": "http://www.registar.kam.hr/Elements/d/#P20012",
      "mappingCurie": "kamd:P20012",
      "mappingBasis": "label"
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "5.7",
      "label": "Povijest primjerka",
      "obligation": "Nije obvezno",
      "required": false,
      "repeatable": true,
      "definition": "Povijest primjerka je nestrukturirani tekst koji sadržava informacije o povijesti primjerka koje nisu odgovarajuće iskazane u drugim elementima podataka, uključujući vlasništvo nad primjerkom, preinake primjerka, povijest čuvanja itd.",
      "property": "http://www.registar.kam.hr/Elements/po/#P50013",
      "mappingCurie": "kamp:P50013",
      "mappingBasis": "label"
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "5.8",
      "label": "Dodani natpisi i oznake",
      "obligation": "Nije obvezno",
      "required": false,
      "repeatable": true,
      "definition": "Dodani natpisi i oznake su riječi, znakovi ili skupovi riječi i/ili znakova koji se javljaju na jedinici građe, a nisu dio njezina izvornog oblikovanja, proizvodnje ili objavljivanja, već su ih tijekom vremena dodali posjednici, vlasnici, korisnici i drugi agenti.",
      "property": null
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "5.9",
      "label": "Napomena o dodanim natpisima i oznakama",
      "obligation": "Nije obvezno",
      "required": false,
      "repeatable": true,
      "definition": "Napomena o dodanim natpisima i oznakama je nestrukturirani ili polustrukturirani tekst u kojemu se navode objašnjenja i druge pojedinosti o dodanim natpisima i oznakama na jedinici građe.",
      "property": null
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "5.10",
      "label": "Način nabave",
      "obligation": "Obvezno kad je primjenjivo",
      "required": true,
      "repeatable": true,
      "definition": "Način nabave je nadzirani naziv, kôd ili druga nadzirana oznaka koja označava neposredan način na koji je jedinica građe dospjela u ustanovu u kojoj je pohranjena.",
      "property": "http://www.registar.kam.hr/Elements/po/#P50009",
      "mappingCurie": "kamp:P50009",
      "mappingBasis": "label"
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "5.11",
      "label": "Napomena o nabavi",
      "obligation": "Nije obvezno",
      "required": false,
      "repeatable": true,
      "definition": "Napomena o nabavi je kratak nestrukturirani tekst u kojemu se navode objašnjenja i druge pojedinosti o neposrednoj nabavi jedinice građe, uključujući način, izvor, mjesto i vrijeme nabave.",
      "property": null
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "5.13",
      "label": "Stanje primjerka",
      "obligation": "Nije obvezno",
      "required": false,
      "repeatable": true,
      "definition": "Stanje primjerka je izraz ili tekst u kojemu se navode informacije o fizičkom stanju primjerka jedinice građe, uključujući opće stanje, oštećenja, ranije provedene postupke zaštite, dijelove koji nedostaju i druga svojstva koja proizlaze iz životnog ciklusa primjerka i/ili razlikuju primjerak od drugih primjeraka istoga pojavnog oblika.",
      "property": "http://www.registar.kam.hr/Elements/po/#P50011",
      "mappingCurie": "kamp:P50011",
      "mappingBasis": "label"
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "5.14",
      "label": "Konzervacija i restauracija",
      "obligation": "Obvezno kad je primjenjivo i dostupno",
      "required": true,
      "repeatable": true,
      "definition": "Konzervacija i restauracija je tekst koji sadržava informacije o konzervatorskim i restauratorskim postupcima provedenima nad jedinicom građe, uključujući mjesto, vrijeme i agente odgovorne za konzervaciju i restauraciju.",
      "property": null
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "6.5",
      "label": "Uvjeti objavljivanja, umnožavanja ili prikazivanja",
      "obligation": "Nije obvezno",
      "required": false,
      "repeatable": true,
      "definition": "Uvjeti objavljivanja, umnožavanja ili prikazivanja su izraz ili tekst koji označava pravna i druga ograničenja vezana uz objavljivanje, umnožavanje i/ili javno prikazivanje sadržaja jedinice građe.",
      "property": null
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "6.6",
      "label": "Tehnički uvjeti pristupa",
      "obligation": "Nije obvezno",
      "required": false,
      "repeatable": true,
      "definition": "Tehnički uvjeti pristupa su izraz ili tekst koji sadržava informacije o opremi, uređaju i/ili sustavu potrebnom za pristup sadržaju jedinice građe.",
      "property": null
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "6.10",
      "label": "Dostupnost primjerka",
      "obligation": "Obvezno kad je primjenjivo",
      "required": true,
      "repeatable": true,
      "definition": "Dostupnost primjerka je izraz, tekst ili druga oznaka koja označava uvjete pod kojima ustanova omogućuje korisnicima pristup primjerku jedinice građe.",
      "property": "http://www.registar.kam.hr/Elements/po/#P50004",
      "mappingCurie": "kamp:P50004",
      "mappingBasis": "label"
    },
