  },
  "@id": "http://www.registar.kam.hr/ApplicationProfiles/#ArhivskeKarte_i_Planovi",
  "@type": "ap:ApplicationProfile",
  "label": "Aplikacijski profil – Arhivske karte i planovi",
  "sourceDocument": "Arhiv_Karte.docx",
  "elementUsage": [
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "1.1",
      "label": "Stvarni prikaz",
      "obligation": "Obvezno kad je primjenjivo i dostupno",
      "required": true,
      "repeatable": true,
      "definition": "Stvarni prikaz je riječ ili skup riječi i/ili znakova koji identificiraju jedinicu građe i pružaju informacije o mjestu, vremenu i agentima povezanima s nastankom jedinice građe, a navedeni su na samoj jedinici.",
      "property": null
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "1.2",
      "label": "Napomena o stvarnom prikazu",
      "obligation": "Nije obvezno",
      "required": false,
      "repeatable": true,
      "definition": "Napomena o stvarnom prikazu je nestrukturirani ili polustrukturirani tekst u kojemu se navode pojedinosti o stvarnom prikazu, uključujući informacije o rasporedu i izvorima podataka stvarnog prikaza na jedinici građe.",
      "property": null
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "1.3",
      "label": "Podatak o stvarnom naslovu",
      "obligation": "Obvezno kad je primjenjivo i dostupno",
      "required": true,
      "repeatable": false,
      "definition": "Podatak o stvarnom naslovu je riječ, znak ili skup riječi i/ili znakova koji imenuje jedinicu građe, a naveden je na samoj jedinici.",
      "property": "http://www.registar.kam.hr/Elements/po/#P40003",
      "mappingCurie": "kampo:P40003",
      "mappingBasis": "label"
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "1.4",
      "label": "Glavni stvarni naslov",
      "obligation": "Obvezno kad je primjenjivo i dostupno",
      "required": true,
      "repeatable": false,
      "definition": "Glavni stvarni naslov je riječ, znak ili skup riječi i/ili znakova koji primarno imenuje jedinicu građe, a naveden je na samoj jedinici.",
      "property": "http://www.registar.kam.hr/Elements/po/#P40004",
      "mappingCurie": "kampo:P40004",
      "mappingBasis": "label"
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "1.5",
      "label": "Usporedni stvarni naslov",
      "obligation": "Nije obvezno",
      "required": false,
      "repeatable": true,
      "definition": "Usporedni stvarni naslov je riječ, znak ili skup riječi i/ili znakova koji je naveden je u istom izvoru podataka na jedinici građe kao i glavni stvarni naslov i predstavlja njegovu istoznačnicu na drugom jeziku i/ili pismu.",
      "property": "http://www.registar.kam.hr/Elements/po/#P40005",
      "mappingCurie": "kampo:P40005",
      "mappingBasis": "label"
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "1.6",
      "label": "Dodatak glavnom stvarnom naslovu",
      "obligation": "Nije obvezno",
      "required": false,
      "repeatable": true,
      "definition": "Dodatak glavnom stvarnom naslovu je riječ, znak ili skup riječi i/ili znakova koji pobliže određuje, objašnjava ili upotpunjuje glavni stvarni naslov, a i naveden je na jedinici građe, na jeziku glavnog stvarnog naslova i u istom izvoru podataka kao i glavni stvarni naslov.",
      "property": "http://www.registar.kam.hr/Elements/po/#P40006",
      "mappingCurie": "kampo:P40006",
      "mappingBasis": "label"
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "1.7",
      "label": "Usporedni dodatak glavnom stvarnom naslovu",
      "obligation": "Nije obvezno",
      "required": false,
      "repeatable": true,
      "definition": "Usporedni dodatak glavnom stvarnom naslovu je riječ, znak ili skup riječi i/ili znakova koji predstavlja istoznačnicu dodatka glavnom stvarnom naslovu na drugom jeziku i/ili pismu, a naveden je u istom izvoru podataka na jedinici građe kao i dodatak glavnom stvarnom naslovu.",
      "property": "http://www.registar.kam.hr/Elements/po/#P40007",
      "mappingCurie": "kampo:P40007",
      "mappingBasis": "label"
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "1.8",
      "label": "Napomena o stvarnom naslovu",
      "obligation": "Obvezno kad je primjenjivo, pod određenim uvjetima (vidi 1.8.2 Uvjeti navođenja napomene o",
      "required": true,
      "repeatable": true,
      "definition": "Napomena o stvarnom naslovu je kratak nestrukturirani tekst u kojemu se navode objašnjenja i druge pojedinosti o stvarnom naslovu, uključujući izvor na jedinici građe iz kojega je podatak o stvarnom naslovu preuzet.",
      "property": null
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "2.1",
      "label": "Razina opisa djela",
      "obligation": "Obvezno kad je primjenjivo",
      "required": true,
      "repeatable": false,
      "definition": "Razina opisa djela je izraz, nadzirani naziv, kôd ili druga oznaka koja označava razinu specifičnosti opisa djela u informacijskom sustavu, uključujući položaj unutar hijerarhije djelâ koja su s njim povezana odnosom cjeline i dijela.",
      "property": null
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "2.2",
      "label": "Razina opisa pojavnog oblika",
      "obligation": "Obvezno kad je primjenjivo",
      "required": true,
      "repeatable": false,
      "definition": "Razina opisa pojavnog oblika je izraz, nadzirani naziv, kôd ili druga oznaka koja označava razinu specifičnosti opisa pojavnog oblika jedinice građe u informacijskom sustavu.",
      "property": null
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "2.4",
      "label": "Medij",
      "obligation": "Obvezno kad je primjenjivo, pod određenim uvjetima (vidi 2.4.2 Uvjeti navođenja medija)",
      "required": true,
      "repeatable": true,
      "definition": "Medij je izraz, nadzirani naziv, identifikator ili druga oznaka koja označava vrstu građe s obzirom na tehnologiju bilježenja, posredovanja i pohrane njezina sadržaja.",
      "property": "http://www.registar.kam.hr/Elements/po/#P40042",
      "mappingCurie": "kampo:P40042",
      "mappingBasis": "label"
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "2.5",
      "label": "Oblik sadržaja",
      "obligation": "Obvezno kad je primjenjivo, pod određenim uvjetima (vidi 2.5.2 Uvjeti navođenja oblika sadržaja)",
      "required": true,
      "repeatable": true,
      "definition": "Oblik sadržaja je izraz, nadzirani naziv, identifikator ili druga oznaka koja označava vrstu građe s obzirom na znakovni sustav kojim je izražen njezin sadržaj.",
      "property": null
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "2.6",
      "label": "Identifikator djela",
      "obligation": "Obvezno kad je primjenjivo, pod određenim uvjetima (vidi 2.6.2 Uvjeti navođenja identifikatora djela)",
      "required": true,
      "repeatable": true,
      "definition": "Identifikator djela je brojčana ili slovno-brojčana oznaka koja unutar određenog sustava jednoznačno identificira djelo sadržano u jedinici građe.",
      "property": "http://www.registar.kam.hr/Elements/d/#P20309",
      "mappingCurie": "kamd:P20309",
      "mappingBasis": "label"
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "2.7",
      "label": "Usvojena pristupnica za djelo",
      "obligation": "Obvezno kad je primjenjivo",
      "required": true,
      "repeatable": false,
      "definition": "Usvojena pristupnica za djelo je nadzirana riječ, izraz ili niz riječi i/ili drugih oznaka, koji unutar nekog sustava jednoznačno identificira djelo i okuplja podatke o djelu.",
      "property": "http://www.registar.kam.hr/Elements/n/#P13022",
      "mappingCurie": "kamn:P13022",
      "mappingBasis": "label"
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "2.8",
      "label": "Usvojeni naslov djela",
      "obligation": "Obvezno kad je primjenjivo",
      "required": true,
      "repeatable": false,
      "definition": "Usvojeni naslov djela je riječ ili niz riječi i/ili drugih oznaka, kojemu se daje prednost u imenovanju djela unutar određenog sustava.",
      "property": "http://www.registar.kam.hr/Elements/d/#P20304",
      "mappingCurie": "kamd:P20304",
      "mappingBasis": "label"
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "2.9",
      "label": "Vrsta usvojenog naslova djela",
      "obligation": "Nije obvezno",
      "required": false,
      "repeatable": true,
      "definition": "Vrsta usvojenog naslova djela je riječ, izraz ili druga oznaka koja označava kojoj vrsti naslova pripada usvojeni naslov djela.",
      "property": "http://www.registar.kam.hr/Elements/n/#P13026",
      "mappingCurie": "kamn:P13026",
      "mappingBasis": "label"
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "2.10",
      "label": "Dodatno obilježje djela",
      "obligation": "Obvezno kad je primjenjivo, pod određenim uvjetima (vidi 2.10.2 Uvjeti navođenja dodatnog obilježja",
      "required": true,
      "repeatable": true,
      "definition": "Dodatno obilježje djela je riječ, brojka ili niz riječi, brojki i/ili drugih znakova, koji služi razlikovanju djelâ koja imaju isti naslov ili razlikovanju djela od drugih jedinica opisa čije je ime jednako ili slično njegovom naslovu.",
      "property": "http://www.registar.kam.hr/Elements/d/#P20307",
      "mappingCurie": "kamd:P20307",
      "mappingBasis": "label"
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "2.12",
      "label": "Varijantna pristupnica za djelo",
      "obligation": null,
      "required": null,
      "repeatable": null,
      "definition": null,
      "property": "http://www.registar.kam.hr/Elements/n/#P13023",
      "mappingCurie": "kamn:P13023",
      "mappingBasis": "label"
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "2.13",
      "label": "Varijantni naslov djela",
      "obligation": "Obvezno kad je primjenjivo, pod određenim uvjetima (vidi 2.13.2 Uvjeti navođenja varijantnog",
      "required": true,
      "repeatable": true,
      "definition": "Varijantni naslov djela je riječ ili niz riječi i/ili drugih oznaka, koji imenuje djelo unutar nekog sustava, a nije odabran za usvojeni naslov djela.",
      "property": "http://www.registar.kam.hr/Elements/d/#P20305",
      "mappingCurie": "kamd:P20305",
      "mappingBasis": "label"
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "2.14",
      "label": "Vrsta varijantnog naslova djela",
      "obligation": "Nije obvezno",
      "required": false,
      "repeatable": true,
      "definition": "Vrsta varijantnog naslova djela je riječ, izraz ili druga oznaka koja označava kojoj vrsti naslova pripada varijantni naslov djela.",
      "property": "http://www.registar.kam.hr/Elements/n/#P13028",
      "mappingCurie": "kamn:P13028",
      "mappingBasis": "label"
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "2.16",
      "label": "Napomena o identifikaciji djela",
      "obligation": "Nije obvezno",
      "required": false,
      "repeatable": true,
      "definition": "Napomena o identifikaciji djela je kratak tekst u kojemu se navode objašnjenja i druge pojedinosti o identifikacijskim podacima o djelu (identifikator djela, usvojeni naslov djela, varijantni naslov djela, ključni naslov, brojčane i kronološke oznake serijske građe) i/ili izvorima iz kojih su identifikacijski podaci preuzeti.",
      "property": null
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "2.17",
      "label": "Identifikator izraza",
      "obligation": "Obvezno kad je primjenjivo i dostupno",
      "required": true,
      "repeatable": true,
      "definition": "Identifikator izraza je brojčana ili slovno-brojčana oznaka koja unutar određenog sustava jednoznačno identificira izraz djela sadržanog u jedinici građe.",
      "property": "http://www.registar.kam.hr/Elements/i/#P30243",
      "mappingCurie": "kami:P30243",
      "mappingBasis": "label"
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "2.18",
      "label": "Usvojena pristupnica za izraz",
      "obligation": "Obvezno kad je primjenjivo",
      "required": true,
      "repeatable": false,
      "definition": "Usvojena pristupnica za izraz je nadzirana riječ, izraz ili niz riječi i/ili drugih oznaka, koji unutar nekog sustava jednoznačno identificira izraz i okuplja podatke o izrazu.",
      "property": "http://www.registar.kam.hr/Elements/n/#P13039",
      "mappingCurie": "kamn:P13039",
      "mappingBasis": "label"
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "2.19",
      "label": "Dodatno obilježje izraza",
      "obligation": "Obvezno kad je primjenjivo, pod određenim uvjetima (vidi 2.19.2 Uvjeti navođenja dodatnog obilježja",
      "required": true,
      "repeatable": true,
      "definition": "Dodatno obilježje izraza je riječ, brojka ili niz riječi, brojki i/ili drugih znakova koji služi razlikovanju izrazâ istoga djela.",
      "property": "http://www.registar.kam.hr/Elements/i/#P30242",
      "mappingCurie": "kami:P30242",
      "mappingBasis": "label"
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "2.20",
      "label": "Varijantna pristupnica za izraz",
      "obligation": "Nije obvezno",
      "required": false,
      "repeatable": true,
      "definition": "Varijantna pristupnica za izraz je riječ, izraz ili niz riječi i/ili drugih oznaka, koji identificira izraz unutar određenog sustava, a nije odabran za usvojenu pristupnicu.",
      "property": "http://www.registar.kam.hr/Elements/n/#P13040",
      "mappingCurie": "kamn:P13040",
      "mappingBasis": "label"
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "2.21",
      "label": "Napomena o identifikaciji izraza",
      "obligation": "Nije obvezno",
      "required": false,
      "repeatable": true,
      "definition": "Napomena o identifikaciji izraza je kratak tekst u kojemu se navode objašnjenja i druge pojedinosti o identifikacijskim podacima o izrazu (identifikator izraza, usvojeni naslov izraza, varijantni naslov izraza) i/ili izvorima iz kojih su identifikacijski podaci preuzeti.",
      "property": null
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "2.22",
      "label": "Identifikator pojavnog oblika",
      "obligation": "Obvezno kad je primjenjivo i dostupno",
      "required": true,
      "repeatable": true,
      "definition": "Identifikator pojavnog oblika je brojčana ili slovno-brojčana oznaka koja unutar određenog sustava jednoznačno identificira pojavni oblik jedinice građe.",
      "property": "http://www.registar.kam.hr/Elements/po/#P40319",
      "mappingCurie": "kampo:P40319",
      "mappingBasis": "label"
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "2.23",
      "label": "Usvojena pristupnica za pojavni oblik",
      "obligation": "Obvezno kad je primjenjivo",
      "required": true,
      "repeatable": false,
      "definition": "Usvojena pristupnica za pojavni oblik je nadzirana riječ, izraz ili niz riječi i/ili drugih oznaka, koji unutar nekog sustava jednoznačno identificira pojavni oblik i okuplja podatke o njemu.",
      "property": "http://www.registar.kam.hr/Elements/n/#P13049",
      "mappingCurie": "kamn:P13049",
      "mappingBasis": "label"
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "2.24",
      "label": "Dodatno obilježje pojavnog oblika",
      "obligation": "Obvezno kad je primjenjivo, pod određenim uvjetima (vidi 2.24.2 Uvjeti navođenja dodatnog obilježja",
      "required": true,
      "repeatable": true,
      "definition": "Dodatno obilježje pojavnog oblika je riječ, brojka ili niz riječi, brojki i/ili drugih znakova, koji služi razlikovanju pojavnih oblika istoga izraza ili razlikovanju pojavnog oblika od drugih jedinica opisa čije je ime jednako ili slično njegovom naslovu.",
      "property": null
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "2.26",
      "label": "Varijantna pristupnica za pojavni oblik",
      "obligation": "Nije obvezno",
      "required": false,
      "repeatable": true,
      "definition": "Varijantna pristupnica za pojavni oblik je riječ, izraz ili niz riječi i/ili drugih oznaka, koji identificira pojavni oblik unutar određenog sustava, a nije odabran za usvojenu pristupnicu.",
      "property": "http://www.registar.kam.hr/Elements/n/#P13050",
      "mappingCurie": "kamn:P13050",
      "mappingBasis": "label"
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "2.27",
      "label": "Varijantni naslov pojavnog oblika",
      "obligation": "Nije obvezno",
      "required": false,
      "repeatable": true,
      "definition": "Varijantni naslov pojavnog oblika je riječ, izraz ili niz riječi i/ili drugih oznaka koji je naveden na jedinici građe i imenuje jedinicu građe, ali nije odabran za glavni stvarni naslov niti se smatra nekim od drugih podelemenata stvarnog naslova, najčešće zato što se nalazi izvan propisanih izvora podataka za stvarni naslov.",
      "property": "http://www.registar.kam.hr/Elements/po/#P40316",
      "mappingCurie": "kampo:P40316",
      "mappingBasis": "label"
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "2.28",
      "label": "Napomena o identifikaciji pojavnog oblika",
      "obligation": "Nije obvezno",
      "required": false,
      "repeatable": true,
      "definition": "Napomena o identifikaciji pojavnog oblika je je kratak tekst u kojemu se navode objašnjenja i druge pojedinosti o identifikacijskim podacima o pojavnom obliku (identifikator pojavnog oblika, usvojeni naslov pojavnog oblika, varijantni naslov pojavnog oblika, skraćeni naslov, dodatno obilježje pojavnog oblika) i/ili izvorima iz kojih su identifikacijski podaci preuzeti.",
      "property": null
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "2.29",
      "label": "Identifikator primjerka",
      "obligation": "Obvezno kad je primjenjivo",
      "required": true,
      "repeatable": true,
      "definition": "Identifikator primjerka je brojčana ili slovno-brojčana oznaka koja unutar određenog sustava jednoznačno identificira primjerak jedinice građe.",
      "property": "http://www.registar.kam.hr/Elements/po/#P50001",
      "mappingCurie": "kamp:P50001",
      "mappingBasis": "label"
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "2.30",
      "label": "Usvojena pristupnica za primjerak",
      "obligation": "Obvezno kad je primjenjivo",
      "required": true,
      "repeatable": false,
      "definition": "Usvojena pristupnica za primjerak je nadzirana riječ, izraz ili niz riječi i/ili drugih oznaka, koji unutar nekog sustava jednoznačno identificira primjerak i okuplja podatke o njemu.",
      "property": "http://www.registar.kam.hr/Elements/n/#P13063",
      "mappingCurie": "kamn:P13063",
      "mappingBasis": "label"
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "2.31",
      "label": "Napomena o identifikaciji primjerka",
      "obligation": "Nije obvezno",
      "required": false,
      "repeatable": true,
      "definition": "Napomena o identifikaciji primjerka je kratak tekst u kojemu se navode objašnjenja i druge pojedinosti o identifikacijskim podacima o primjerku i/ili izvorima iz kojih su identifikacijski podaci preuzeti.",
      "property": null
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "2.32",
      "label": "Preporučeni način citiranja",
      "obligation": "Nije obvezno",
      "required": false,
      "repeatable": true,
      "definition": "Preporučeni način citiranja je način koji ustanova preporučuje za citiranje jedinice građe koje posjeduje i/ili za čiji je nastanak ili sređivanje odgovorna (npr. fondovi, zbirke, baze podataka, aplikacije itd.).",
      "property": null
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "3.1",
      "label": "Izvorni natpisi i oznake",
      "obligation": "Obvezno kad je primjenjivo i dostupno",
      "required": true,
      "repeatable": true,
      "definition": "Izvorni natpisi i oznake su riječi, znakovi ili skupovi riječi i/ili znakova koji se javljaju na jedinici građe (najčešće na epigrafskim spomenicima, uporabnim predmetima i drugim kulturnim objektima ili slikovnoj građi) kao dio izvornog oblikovanja, a predstavljaju sadržaj ili dio sadržaja (npr. dekorativni natpisi, citati, zazivi, gesla i sl.).",
      "property": null
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "3.2",
      "label": "Napomena o izvornim natpisima i oznakama",
      "obligation": "Nije obvezno",
      "required": false,
      "repeatable": true,
      "definition": "Napomena o izvornim natpisima i oznakama je nestrukturirani ili polustrukturirani tekst u kojemu se navode objašnjenja i druge pojedinosti o izvornim natpisima i oznakama na jedinici građe.",
      "property": null
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "3.3",
      "label": "Opis sadržaja",
      "obligation": "Nije obvezno",
      "required": false,
      "repeatable": true,
      "definition": "Opis sadržaja je kratak nestrukturirani tekst koji objašnjava o čemu je ili što prikazuje jedinica građe.",
      "property": null
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "3.5",
      "label": "Predmet",
      "obligation": "Obvezno kad je primjenjivo, pod određenim uvjetima (vidi 3.5.2 Uvjeti navođenja predmeta)",
      "required": true,
      "repeatable": true,
      "definition": "Predmet je izraz, nadzirani naziv, ime, naslov, identifikator ili druga nadzirana oznaka koja označava temu kojom se bavi ili koju prikazuje jedinica građe.",
      "property": null
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "3.6",
      "label": "Napomena o predmetu",
      "obligation": "Nije obvezno",
      "required": false,
      "repeatable": true,
      "definition": "Napomena o predmetu je kratak nestrukturirani tekst u kojemu se navode objašnjenja, tumačenja i druge pojedinosti o predmetu jedinice građe i/ili načinu na koji je predmet utvrđen.",
      "property": null
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "3.7",
      "label": "Područje",
      "obligation": "Obvezno kad je primjenjivo",
      "required": true,
      "repeatable": true,
      "definition": "Područje je izraz, nadzirani naziv, identifikator ili druga oznaka koja označava djelatnost, znanstvenu disciplinu ili drugo polje ljudskog znanja ili djelovanja kojemu pripada sadržaj jedinice građe unutar određenog klasifikacijskog sustava.",
      "property": null
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "3.8",
      "label": "Oblik ili žanr",
      "obligation": "Nije obvezno",
      "required": false,
      "repeatable": true,
      "definition": "Oblik ili žanr je izraz, nadzirani naziv, identifikator ili druga oznaka koja označava vrstu kojoj pripada jedinica građe s obzirom na namjenu i organizaciju sadržaja, odabir teme i stila i druge pretežito sadržajne značajke.",
      "property": "http://www.registar.kam.hr/Elements/d/#P20315",
      "mappingCurie": "kamd:P20315",
      "mappingBasis": "label"
    },
    {
