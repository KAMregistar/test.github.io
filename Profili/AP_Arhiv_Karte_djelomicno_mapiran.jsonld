    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "3.27",
      "label": "Kartografska projekcija",
      "obligation": "Nije obvezno",
      "required": false,
      "repeatable": true,
      "definition": "Kartografska projekcija je izraz ili druga oznaka koja označava matematički sustav pomoću kojega je na karti prikazana Zemlja ili neko drugo nebesko tijelo, dio Zemlje ili nekog drugog nebeskog tijela ili položaj nebeskih tijela.",
      "property": null
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "3.28",
      "label": "Geografska dužina i geografska širina",
      "obligation": "Obvezno kad je primjenjivo i dostupno",
      "required": true,
      "repeatable": false,
      "definition": "Geografska dužina i geografska širina je izraz koji je naveden na kartografskoj jedinici građe, a označava položaj mjesta prikazanog na karti Zemlje ili nekog drugog nebeskog tijela, mjereno od početnog meridijana u pravcu istoka ili zapada te od ekvatora u pravcu sjevera ili juga.",
      "property": null
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "3.29",
      "label": "Napomena o geografskoj dužini i geografskoj širini",
      "obligation": "Nije obvezno",
      "required": false,
      "repeatable": true,
      "definition": "Napomena o geografskoj dužini i geografskoj širini je kratak nestrukturirani tekst u kojemu se navode objašnjenja i druge pojedinosti o geografskoj dužini i geografskoj širini prikaza na jedinici građe.",
      "property": null
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "3.30",
      "label": "Rektascenzija i deklinacija",
      "obligation": "Obvezno kad je primjenjivo i dostupno",
      "required": true,
      "repeatable": false,
      "definition": "Rektascenzija i deklinacija je izraz koji je naveden na kartografskoj jedinici građe, a označava položaj područja neba: kutnu udaljenost mjerenu prema istoku na ekvatoru od proljetne ravnodnevice do satnog kruga nebeskog tijela, od 0 do 24 sata, te kutnu udaljenost do nebeskog tijela mjerenu sjeverno ili južno pomoću 90˚ od nebeskog ekvatora uzduž kruga tijela u satu.",
      "property": null
    },
    {
      "@type": "ap:ElementUsage",
      "elementNumber": "3.31",
      "label": "Ravnodnevica",
      "obligation": "Nije obvezno",
      "required": false,
      "repeatable": false,
      "definition": "Ravnodnevica je izraz koji se javlja na kartografskoj jedinici građe, a označava jednu ili dvije točke sjecišta ekliptičnog i nebeskog ekvatora, zauzetog Suncem kad je njegova deklinacija 0˚.",
      "property": null
    },
